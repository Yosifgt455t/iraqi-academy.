rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.email.lower() == "jwjwjwjueue@gmail.com".lower();
    }

    function isAdmin() {
      return isSuperAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.token.email.lower())));
    }

    function isValidReview(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.url is string && data.url.size() <= 1000 &&
             (data.description == null || (data.description is string && data.description.size() <= 1000)) &&
             (data.subjectIds == null || data.subjectIds is list) &&
             (data.gradeIds == null || data.gradeIds is list);
    }

    function isValidQuizQuestion(data) {
      return data.question is string && data.question.size() <= 1000 &&
             data.options is list && data.options.size() == 4 &&
             data.options[0] is string &&
             data.correctAnswer is int && data.correctAnswer >= 0 && data.correctAnswer <= 3 &&
             data.difficulty is int && data.difficulty >= 1 && data.difficulty <= 15;
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow get: if isSignedIn(); 
      allow list: if isSignedIn(); 
      
      allow create: if isOwner(userId) && 
        incoming().uid == request.auth.uid;

      allow update: if isOwner(userId) &&
        incoming().uid == existing().uid;
    }

    // --- Forum Collections ---
    match /forum_posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn() && incoming().authorId == request.auth.uid;
      allow update: if isSignedIn() && (existing().authorId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (existing().authorId == request.auth.uid || isAdmin());
    }

    match /forum_comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn() && incoming().authorId == request.auth.uid;
      allow update: if isSignedIn() && (existing().authorId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (existing().authorId == request.auth.uid || isAdmin());
    }

    match /news/{newsId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /review_subjects/{subjectId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /review_materials/{materialId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Admins Collection ---
    match /admins/{email} {
      // Allow any user to check if they are an admin via getDoc (id must be their email)
      allow get: if isSignedIn() && request.auth.token.email.lower() == email.lower();
      // Only the Super Admin can list all admins or modify the list
      allow list: if isSuperAdmin();
      allow write: if isSuperAdmin();
    }

    // --- Exams Collection ---
    match /exams/{examId} {
      // Teachers can read their own exams
      allow get: if isSignedIn() && existing().teacherId == request.auth.uid;
      // Protected list query: must filter by teacherId
      allow list: if isSignedIn() && resource.data.teacherId == request.auth.uid;
      
      allow create: if isSignedIn();
      allow update: if isSignedIn() && existing().teacherId == request.auth.uid;
      allow delete: if isSignedIn() && existing().teacherId == request.auth.uid;
    }

    // --- Curriculum Collections (Public Read for Authenticated Users/Guests) ---
    match /classes/{doc=**} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    match /subjects/{doc=**} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    match /chapters/{doc=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /materials/{doc=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /flashcards/{doc=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /ministerial_questions/{doc=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /teachers/{doc=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if isAdmin() && isValidReview(incoming());
    }

    match /quiz_questions/{questionId} {
      allow read: if true;
      allow write: if isAdmin() && isValidQuizQuestion(incoming());
    }

    // --- Settings Collection (Maintenance Mode) ---
    match /settings/{id} {
      // Allow everyone to read the status to see if site is in maintenance
      allow read: if true; 
      // Only the Super Admin can change settings
      allow write: if isSuperAdmin();
    }

    // --- AI Chats Collection ---
    match /ai_chats/{chatId} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() &&
        isValidId(chatId) == false && // addDoc generated ID
        incoming().userId == request.auth.uid &&
        incoming().createdAt is string;

      allow update: if isSignedIn() &&
        existing().userId == request.auth.uid &&
        incoming().userId == existing().userId &&
        incoming().diff(existing()).affectedKeys().hasOnly(['messages', 'title', 'updatedAt']);

      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // --- Sources Collection ---
    match /sources/{sourceId} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() &&
        incoming().userId == request.auth.uid &&
        incoming().title is string &&
        incoming().type in ['pdf', 'link', 'text', 'youtube'];

      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
