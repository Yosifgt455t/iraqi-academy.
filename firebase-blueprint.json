{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores basic user information and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the user." },
        "displayName": { "type": "string", "description": "User's display name." },
        "email": { "type": "string", "description": "User's email address." },
        "photoURL": { "type": "string", "description": "URL to the user's profile picture." },
        "grade": { "type": "string" },
        "xp": { "type": "number", "default": 0 },
        "level": { "type": "number", "default": 1 },
        "streak": {
          "type": "object",
          "properties": {
            "count": { "type": "number" },
            "lastUpdate": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the account was created." }
      },
      "required": ["uid", "email"]
    },
    "Exam": {
      "title": "Saved Exam",
      "description": "An exam created and saved by a teacher.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "teacherId": { "type": "string" },
        "schoolName": { "type": "string" },
        "subject": { "type": "string" },
        "examType": { "type": "string" },
        "academicYear": { "type": "string" },
        "questions": { 
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "text": { "type": "string" },
              "branches": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["teacherId", "subject", "questions"]
    },
    "Subject": {
      "title": "Subject",
      "description": "A study subject for a specific grade.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "grade": { "type": "string" },
        "icon": { "type": "string" }
      },
      "required": ["name", "grade"]
    },
    "Chapter": {
      "title": "Chapter",
      "description": "A chapter within a subject.",
      "type": "object",
      "properties": {
        "subjectId": { "type": "string" },
        "name": { "type": "string" },
        "orderIndex": { "type": "number" }
      },
      "required": ["subjectId", "name"]
    },
    "Material": {
      "title": "Material (Lecture)",
      "description": "An educational resource like a PDF or Video.",
      "type": "object",
      "properties": {
        "chapterId": { "type": "string" },
        "teacherId": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["PDF", "Video", "Ministerial"] },
        "url": { "type": "string" }
      },
      "required": ["chapterId", "title", "type", "url"]
    },
    "Teacher": {
      "title": "Teacher",
      "description": "Information about a teacher for a specific subject.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "subjectId": { "type": "string" },
        "avatar": { "type": "string" }
      },
      "required": ["name", "subjectId"]
    },
    "Flashcard": {
      "title": "Flashcard",
      "description": "A digital flashcard for smart testing.",
      "type": "object",
      "properties": {
        "chapterId": { "type": "string" },
        "chapterIds": { "type": "array", "items": { "type": "string" } },
        "question": { "type": "string" },
        "answer": { "type": "string" }
      },
      "required": ["question", "answer"]
    },
    "Class": {
      "title": "Class Stage",
      "description": "Defines educational stages and their grades (e.g., Primary, Middle).",
      "type": "object",
      "properties": {
        "label": { "type": "string" },
        "iconName": { "type": "string" },
        "color": { "type": "string" },
        "orderIndex": { "type": "number" },
        "grades": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        }
      }
    },
    "MinisterialQuestion": {
      "title": "Ministerial Question",
      "description": "Structured historical exam question with answer and year.",
      "type": "object",
      "properties": {
        "chapterIds": { "type": "array", "items": { "type": "string" } },
        "question": { "type": "string" },
        "answer": { "type": "string" },
        "year": { "type": "string" }
      },
      "required": ["question", "answer", "year"]
    },
    "Chat": {
      "title": "Chat",
      "description": "An AI chat session storage.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "messages": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Source": {
      "title": "Source",
      "description": "A learning source saved by the user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["pdf", "link", "text", "youtube"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Review": {
      "title": "Focused Review",
      "description": "Educational reviews or summaries for specific subjects.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subjectIds": { "type": "array", "items": { "type": "string" } },
        "gradeIds": { "type": "array", "items": { "type": "string" } },
        "url": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "url"]
    },
    "QuizQuestion": {
      "title": "Millionaire Quiz Question",
      "description": "Questions for the Millionaire-style game.",
      "type": "object",
      "properties": {
        "question": { "type": "string" },
        "options": { "type": "array", "items": { "type": "string" } },
        "correctAnswer": { "type": "number" },
        "difficulty": { "type": "number" },
        "subjectId": { "type": "string" }
      },
      "required": ["question", "options", "correctAnswer"]
    },
    "ForumPost": {
      "title": "Forum Post",
      "description": "A community discussion post.",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "subjectId": { "type": "string" },
        "likes": { "type": "number" },
        "commentCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorId", "title", "content"]
    },
    "ForumComment": {
      "title": "Forum Comment",
      "description": "A comment on a forum post.",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["postId", "authorId", "content"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User account documents."
    },
    "/classes/{stageId}": {
      "schema": "Class",
      "description": "Educational stages and grades hierarchy."
    },
    "/exams/{examId}": {
      "schema": "Exam",
      "description": "Exams collection."
    },
    "/subjects/{subjectId}": {
      "schema": "Subject",
      "description": "All subjects across all grades."
    },
    "/chapters/{chapterId}": {
      "schema": "Chapter",
      "description": "Chapters for subjects."
    },
    "/materials/{materialId}": {
      "schema": "Material",
      "description": "Lectures, PDFs, and videos."
    },
    "/teachers/{teacherId}": {
      "schema": "Teacher",
      "description": "Teachers collection."
    },
    "/flashcards/{flashcardId}": {
      "schema": "Flashcard",
      "description": "Smart study cards."
    },
    "/ministerial_questions/{questionId}": {
      "schema": "MinisterialQuestion",
      "description": "Structured ministerial exam questions."
    },
    "/ai_chats/{chatId}": {
      "schema": "Chat",
      "description": "AI chat history."
    },
    "/sources/{sourceId}": {
      "schema": "Source",
      "description": "User's saved sources for contextual AI AI."
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Focused reviews for students."
    },
    "/quiz_questions/{questionId}": {
      "schema": "QuizQuestion",
      "description": "Millionaire game questions."
    },
    "/forum_posts/{postId}": {
      "schema": "ForumPost",
      "description": "Community posts."
    },
    "/forum_comments/{commentId}": {
      "schema": "ForumComment",
      "description": "Comments on community posts."
    },
    "/news/{newsId}": {
      "schema": "NewsItem",
      "description": "Platform global news."
    },
    "/review_subjects/{subjectId}": {
      "schema": "ReviewSubject",
      "description": "Subjects in the review section."
    },
    "/review_materials/{materialId}": {
      "schema": "ReviewMaterial",
      "description": "Files/Videos inside a review subject."
    }
  }
}
